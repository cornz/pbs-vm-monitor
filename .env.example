# PBS connection
PBS_BASE_URL=https://127.0.0.1:8007
PBS_DATASTORE=offsite
# Option 1: full token value after `PBSAPIToken=`
PBS_API_TOKEN=userName@pbs!replaceMe:withYourSecret
# Option 2: split token id and secret instead of PBS_API_TOKEN
# PBS_TOKEN_ID=userName@pbs!replaceMe
# PBS_TOKEN_SECRET=withYourSecret
# Option 3: full Authorization value
# PBS_AUTHORIZATION=PBSAPIToken=userName@pbs!replaceMe:withYourSecret
# Set to false if your PBS instance uses a self-signed certificate.
PBS_VERIFY_TLS=false

# Backup freshness threshold
MAX_BACKUP_AGE_HOURS=24
REQUEST_TIMEOUT_SECONDS=30

# HTTP endpoint for your monitoring system
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
